rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{id} { allow read, write: if request.auth != null; }
    match /masters/{id} { allow read, write: if request.auth != null; }
    match /jobs/{id} { allow read, write: if request.auth != null; }
    match /stages/{id} { allow read, write: if request.auth != null; }
    match /settings/{id} { allow read, write: if request.auth != null; }
    match /queue/{id} { allow read, write: if request.auth != null; }
    match /cells/{id} { allow read, write: if request.auth != null; }
    match /warehouseConfig/{id} { allow read, write: if request.auth != null; }
    match /warehouseLog/{id} { allow read, write: if request.auth != null; }
    match /orderDocuments/{id} { allow read, write: if request.auth != null; }
    match /{document=**} { allow read, write: if false; }
  }
}
